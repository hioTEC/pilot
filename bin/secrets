#!/bin/bash
# secrets — age-encrypted secrets management
# Usage: secrets show        Decrypt + print env
#        secrets edit        Edit env, re-encrypt
#        secrets env [DIR]   Decrypt .env + extract keys
#        secrets import-key  Add .pem to bundle
#        secrets push HOST   SCP .secrets.age to remote
#        secrets setup-remote HOST  Full remote bootstrap
#
# Architecture:
#   .secrets.age = age-encrypted tar.gz containing:
#     - .env (shell env vars: API keys, cloud creds, etc.)
#     - keys/*.pem (SSH private keys)
#
#   Age key stored in:
#     - macOS: Keychain (security find-generic-password)
#     - Linux: ~/.config/age/key.txt
#
#   This is a template — implement encrypt/decrypt based on your needs.
set -euo pipefail

echo "secrets: template — customize for your setup"
echo "See: https://github.com/FiloSottile/age"
